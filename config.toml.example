# arxiv-coffee configuration
# Copy this file to ~/.config/arxiv-coffee/config.toml and edit as needed.

[llm]
# API key for your LLM provider (required for most providers)
# Leave empty when using github_copilot/ — it authenticates via OAuth device flow.
api_key = ""

# Model identifier in litellm format.
# Examples:
#   "openai/gpt-4o"
#   "openai/gpt-4o-mini"
#   "anthropic/claude-sonnet-4-20250514"
#   "anthropic/claude-3-haiku-20240307"
#   "github_copilot/gpt-4o"              (uses your GitHub Copilot subscription)
#   "github_copilot/claude-sonnet-4-20250514"
#   "github/gpt-4o"                      (GitHub Models — needs GITHUB_API_KEY)
model = "openai/gpt-4o"

# Optional: custom API base URL (e.g. for a local or proxy endpoint)
# base_url = "https://api.example.com/v1"

[arxiv]
# arXiv categories to fetch papers from.
# Common HEP categories: hep-ph, hep-th, hep-ex, hep-lat
# See https://arxiv.org/category_taxonomy for the full list.
categories = ["hep-ph"]

# Maximum number of papers to fetch per query
max_papers = 100

# Include cross-posted papers (papers whose primary category differs from the
# searched category). Set to true to include them, false to exclude.
include_cross_posts = false

[paths]
# Path to a markdown file describing your research interests.
# This is sent to the AI to help it filter relevant papers.
interests_file = "~/.config/arxiv-coffee/interests.md"

# Directory where paper summaries and the library index are stored.
output_dir = "~/arxiv-coffee-library"
