#!/usr/bin/env bash
#
# arxiv-coffee — launcher script for arxiv-coffee
#
# Ensures a virtualenv exists with all dependencies installed,
# then runs the TUI app. Uses uv if available, falls back to pip.
#

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_DIR="${SCRIPT_DIR}/.venv"
MIN_PYTHON_MAJOR=3
MIN_PYTHON_MINOR=12

# ── Helpers ──────────────────────────────────────────────────────────

die() {
  printf '\033[1;31merror:\033[0m %s\n' "$1" >&2
  exit 1
}

info() {
  printf '\033[1;34m::\033[0m %s\n' "$1"
}

# Find a suitable python3 interpreter (>= 3.12).
# Checks: python3, python3.14, python3.13, python3.12, python.
find_python() {
  local candidates=("python3" "python3.14" "python3.13" "python3.12" "python")
  for cmd in "${candidates[@]}"; do
    if command -v "$cmd" &>/dev/null; then
      local ver
      ver="$("$cmd" -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null)" || continue
      local major minor
      major="${ver%%.*}"
      minor="${ver#*.}"
      if [ "$major" -ge "$MIN_PYTHON_MAJOR" ] && [ "$minor" -ge "$MIN_PYTHON_MINOR" ]; then
        echo "$cmd"
        return 0
      fi
    fi
  done
  return 1
}

# ── uv path ──────────────────────────────────────────────────────────

setup_with_uv() {
  info "Using uv for environment management"

  # uv sync handles venv creation + dependency install in one step
  (cd "$SCRIPT_DIR" && uv sync --quiet)
}

# ── pip path ─────────────────────────────────────────────────────────

setup_with_pip() {
  local python="$1"
  info "Using pip for environment management (python: $python)"

  # Create venv if it doesn't exist
  if [ ! -d "$VENV_DIR" ]; then
    info "Creating virtualenv at ${VENV_DIR}"
    "$python" -m venv "$VENV_DIR"
  fi

  # Activate
  # shellcheck disable=SC1091
  source "${VENV_DIR}/bin/activate"

  # Install/upgrade the project in editable mode (picks up pyproject.toml deps)
  # Only reinstall if pyproject.toml is newer than the install marker.
  local marker="${VENV_DIR}/.arxiv-coffee-installed"
  if [ ! -f "$marker" ] || [ "$SCRIPT_DIR/pyproject.toml" -nt "$marker" ]; then
    info "Installing dependencies..."
    pip install --quiet --upgrade pip
    pip install --quiet -e "$SCRIPT_DIR"
    touch "$marker"
  fi
}

# ── Main ─────────────────────────────────────────────────────────────

main() {
  # Decide which tool chain to use
  if command -v uv &>/dev/null; then
    setup_with_uv
    exec uv run --project "$SCRIPT_DIR" python -m arxiv_coffee.app
  else
    local python
    python="$(find_python)" || die "Python >= ${MIN_PYTHON_MAJOR}.${MIN_PYTHON_MINOR} is required but not found in PATH."
    setup_with_pip "$python"
    exec python -m arxiv_coffee.app
  fi
}

main "$@"
